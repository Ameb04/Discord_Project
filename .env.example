# Django
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/0

# Frontend
# Leave VITE_API_BASE_URL empty in dev to use Vite's /api proxy (recommended).
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# Media
MEDIA_ROOT=/app/media
MEDIA_URL=/media/