# Django
DEBUG=True
SECRET_KEY=change-me
# 'backend' is required in Docker: the Vite proxy forwards /api to backend:8000.
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/0

# Frontend
# Leave VITE_API_BASE_URL empty in dev to use Vite's /api proxy (recommended).
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# Media (local filesystem fallback, used only when USE_S3=False)
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# Object storage (MinIO / S3-compatible)
# When USE_S3=True, avatars go to the public bucket and chat attachments to the
# private bucket. docker-compose already wires these for the bundled MinIO.
USE_S3=True
S3_ENDPOINT_URL=http://minio:9000     # backend -> MinIO (server side)
S3_PUBLIC_URL=http://localhost:9000   # browser -> MinIO (public avatars)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
S3_PUBLIC_BUCKET=media
S3_PRIVATE_BUCKET=private-media